# 공통
LOG_LEVEL=INFO
OUTPUT_DIR=./output
REPORT_AUTHOR=박진영

# 크롤러
CHROME_DRIVER_PATH=auto
CRAWL_DELAY_SECONDS=1.5
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# 감성 분석 (Level 3 — LLM API 사용 시)
OPENAI_API_KEY=
SENTIMENT_MODEL=gpt-4o-mini
SENTIMENT_BATCH_SIZE=10

# ML/DL
RANDOM_SEED=42
TEST_SIZE=0.3

# 배포
GCP_PROJECT_ID=
GCP_REGION=asia-northeast3
